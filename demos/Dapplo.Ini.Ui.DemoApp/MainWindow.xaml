<Window x:Class="Dapplo.Ini.Ui.DemoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Dapplo.Ini.Ui Demo"
        Width="540" Height="420"
        MinWidth="420" MinHeight="340"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackground}">

    <!--
        WindowChrome extends our custom titlebar row into the non-client area,
        giving us drag-to-move, edge/corner resize, snap layouts and Aero Snap
        while keeping full control over the visual appearance.
    -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="5"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Custom titlebar row (height matches WindowChrome.CaptionHeight) -->
            <RowDefinition Height="40"/>
            <!-- Page content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Custom titlebar ──────────────────────────────────────────── -->
        <Grid Grid.Row="0"
              Background="{DynamicResource TitleBarBg}">

            <!-- App title (left-aligned, fills the draggable area) -->
            <TextBlock Text="Dapplo.Ini.Ui — WPF Demo"
                       Foreground="{DynamicResource TitleBarFg}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="14,0,138,0"/>

            <!-- Window control buttons (right-aligned).
                 IsHitTestVisibleInChrome="True" is required so that clicks on
                 buttons in the WindowChrome caption area are forwarded to the
                 button rather than treated as caption drag/double-click. -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">

                <Button x:Name="MinimizeButton"
                        Style="{DynamicResource TitleBarButtonStyle}"
                        Content="&#x2013;"
                        ToolTip="Minimise"
                        Click="MinimizeButton_Click"/>

                <Button x:Name="MaximizeRestoreButton"
                        Style="{DynamicResource TitleBarButtonStyle}"
                        Content="&#x25A1;"
                        ToolTip="Maximise"
                        Click="MaximizeRestoreButton_Click"/>

                <Button x:Name="CloseButton"
                        Style="{DynamicResource TitleBarCloseButtonStyle}"
                        Content="&#x2715;"
                        ToolTip="Close"
                        Click="CloseButton_Click"/>

            </StackPanel>
        </Grid>

        <!-- ── Page content ─────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20,16,20,20">

                <!-- ── Header ───────────────────────────────────────────── -->
                <TextBlock Text="Settings overview"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource AppForeground}"
                           Margin="0,0,0,4"/>

                <TextBlock TextWrapping="Wrap"
                           Foreground="{DynamicResource AppSubtext}"
                           Margin="0,0,0,20">
                    Settings are loaded from an INI file at startup and persisted on
                    exit. Click <Bold>Open Settings</Bold> to edit them.
                </TextBlock>

                <!-- ── Open Settings button ─────────────────────────────── -->
                <Button x:Name="OpenSettingsButton"
                        Content="Open Settings…"
                        HorizontalAlignment="Left"
                        Width="148"
                        Margin="0,0,0,24"
                        Click="OpenSettingsButton_Click"/>

                <!-- ── Current values card ──────────────────────────────── -->
                <Border Background="{DynamicResource AppSurface}"
                        BorderBrush="{DynamicResource AppBorder}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,12,16,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Section heading -->
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                   Text="CURRENT SETTINGS"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppSubtext}"
                                   Margin="0,0,0,10"/>

                        <!-- General -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="App name"
                                   Foreground="{DynamicResource AppSubtext}"
                                   Margin="0,4,20,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="AppNameValue"
                                   Foreground="{DynamicResource AppForeground}"
                                   Margin="0,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Start with Windows"
                                   Foreground="{DynamicResource AppSubtext}"
                                   Margin="0,4,20,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="StartupValue"
                                   Foreground="{DynamicResource AppForeground}"
                                   Margin="0,4"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Language"
                                   Foreground="{DynamicResource AppSubtext}"
                                   Margin="0,4,20,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LanguageValue"
                                   Foreground="{DynamicResource AppForeground}"
                                   Margin="0,4"/>

                        <!-- Appearance -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Dark mode"
                                   Foreground="{DynamicResource AppSubtext}"
                                   Margin="0,4,20,4"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DarkModeValue"
                                   Foreground="{DynamicResource AppForeground}"
                                   Margin="0,4"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Accent colour"
                                   Foreground="{DynamicResource AppSubtext}"
                                   Margin="0,4,20,4"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="AccentColorValue"
                                   Foreground="{DynamicResource AppForeground}"
                                   Margin="0,4"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Font size"
                                   Foreground="{DynamicResource AppSubtext}"
                                   Margin="0,4,20,4"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="FontSizeValue"
                                   Foreground="{DynamicResource AppForeground}"
                                   Margin="0,4"/>

                        <!-- Network -->
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Use proxy"
                                   Foreground="{DynamicResource AppSubtext}"
                                   Margin="0,4,20,4"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="UseProxyValue"
                                   Foreground="{DynamicResource AppForeground}"
                                   Margin="0,4"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Proxy"
                                   Foreground="{DynamicResource AppSubtext}"
                                   Margin="0,4,20,4"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" x:Name="ProxyValue"
                                   Foreground="{DynamicResource AppForeground}"
                                   Margin="0,4"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Window>
