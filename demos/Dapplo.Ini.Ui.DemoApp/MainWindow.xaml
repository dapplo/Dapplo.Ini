<Window x:Class="Dapplo.Ini.Ui.DemoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dapplo.Ini.Ui Demo"
        Width="520" Height="380"
        WindowStartupLocation="CenterScreen">

    <DockPanel Margin="16">

        <!-- ── Title ──────────────────────────────────────────────────────── -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Dapplo.Ini.Ui — WPF Demo"
                   FontSize="18" FontWeight="SemiBold"
                   Margin="0,0,0,4"/>

        <TextBlock DockPanel.Dock="Top"
                   TextWrapping="Wrap"
                   Foreground="Gray"
                   Margin="0,0,0,16">
            Settings are loaded from an INI file at startup and persisted on exit.
            Click <Bold>Open Settings</Bold> to edit them.
        </TextBlock>

        <!-- ── Button ─────────────────────────────────────────────────────── -->
        <Button DockPanel.Dock="Top"
                x:Name="OpenSettingsButton"
                Content="Open Settings…"
                HorizontalAlignment="Left"
                Width="140" Height="32"
                Margin="0,0,0,20"
                Click="OpenSettingsButton_Click"/>

        <!-- ── Current values display ─────────────────────────────────────── -->
        <GroupBox DockPanel.Dock="Top" Header="Current settings" Padding="10,6,10,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- General -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="App name:" FontWeight="Bold" Margin="0,3,12,3"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AppNameValue"       Margin="0,3"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Start with Windows:" FontWeight="Bold" Margin="0,3,12,3"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="StartupValue"       Margin="0,3"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Language:" FontWeight="Bold" Margin="0,3,12,3"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="LanguageValue"      Margin="0,3"/>

                <!-- Appearance -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Dark mode:" FontWeight="Bold" Margin="0,3,12,3"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DarkModeValue"      Margin="0,3"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Accent color:" FontWeight="Bold" Margin="0,3,12,3"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="AccentColorValue"   Margin="0,3"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Font size:" FontWeight="Bold" Margin="0,3,12,3"/>
                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="FontSizeValue"      Margin="0,3"/>

                <!-- Network -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Use proxy:" FontWeight="Bold" Margin="0,3,12,3"/>
                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="UseProxyValue"      Margin="0,3"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Proxy:" FontWeight="Bold" Margin="0,3,12,3"/>
                <TextBlock Grid.Row="7" Grid.Column="1" x:Name="ProxyValue"         Margin="0,3"/>
            </Grid>
        </GroupBox>

    </DockPanel>
</Window>
