<Application x:Class="Dapplo.Ini.Ui.DemoApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--
                    Active theme dictionary — swapped at runtime by ThemeManager
                    based on IAppearanceSettings.DarkMode.  Must be the last entry
                    in the merged list so ThemeManager.Apply() can replace it.
                -->
                <ResourceDictionary Source="Themes/LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
