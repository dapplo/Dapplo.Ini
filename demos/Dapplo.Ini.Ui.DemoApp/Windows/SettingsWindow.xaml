<Window x:Class="Dapplo.Ini.Ui.DemoApp.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="620" Height="520"
        MinWidth="480" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Subtle separator line style used between the TabControl and the button row -->
        <Style x:Key="SeparatorStyle" TargetType="Separator">
            <Setter Property="Margin" Value="0,4,0,4"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ── Button bar ──────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                Padding="8,8,8,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                <!--
                    OK  — applies pending changes to all sections and closes the window.
                    For OnConfirm sections (e.g. INetworkSettings) this calls Commit().
                -->
                <Button x:Name="OkButton"
                        Content="_OK"
                        Width="90" Height="28"
                        Margin="0,0,6,0"
                        IsDefault="True"
                        Click="OkButton_Click"/>

                <!--
                    Cancel — rolls back all pending changes and closes the window.
                    For OnConfirm sections this calls Rollback() to restore the snapshot
                    that was taken when BeginSession() was called.
                -->
                <Button x:Name="CancelButton"
                        Content="_Cancel"
                        Width="90" Height="28"
                        Margin="0,0,6,0"
                        IsCancel="True"
                        Click="CancelButton_Click"/>

                <!--
                    Apply — applies pending changes but keeps the window open so the
                    user can continue editing.
                -->
                <Button x:Name="ApplyButton"
                        Content="_Apply"
                        Width="90" Height="28"
                        Click="ApplyButton_Click"/>

            </StackPanel>
        </Border>

        <!--
            TabControl populated dynamically in the code-behind.
            Each tab corresponds to one IIniSection annotated with [UiPage].
            The tab content is built by WpfSettingsRenderer.BuildPage().
        -->
        <TabControl x:Name="PagesTabControl"
                    Margin="6,6,6,0"
                    TabStripPlacement="Left"/>

    </DockPanel>
</Window>
