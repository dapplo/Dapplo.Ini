<Window x:Class="Dapplo.Ini.Ui.DemoApp.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Settings"
        Width="660" Height="540"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackground}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="5"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Custom titlebar -->
            <RowDefinition Height="40"/>
            <!-- TabControl fills the remaining space -->
            <RowDefinition Height="*"/>
            <!-- OK / Cancel / Apply button bar -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Custom titlebar ──────────────────────────────────────────── -->
        <Grid Grid.Row="0"
              Background="{DynamicResource TitleBarBg}">

            <TextBlock Text="Settings"
                       Foreground="{DynamicResource TitleBarFg}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="14,0,50,0"/>

            <!-- Only a Close button for this dialog; OK/Cancel are below. -->
            <Button x:Name="TitleBarCloseButton"
                    Style="{DynamicResource TitleBarCloseButtonStyle}"
                    Content="&#x2715;"
                    ToolTip="Close"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="TitleBarCloseButton_Click"/>
        </Grid>

        <!-- ── Settings pages (populated in code-behind) ────────────────── -->
        <TabControl x:Name="PagesTabControl"
                    Grid.Row="1"
                    Margin="0"
                    TabStripPlacement="Left"/>

        <!-- ── Button bar ───────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource AppBorder}"
                BorderThickness="0,1,0,0"
                Background="{DynamicResource AppBackground}"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,4,0">

                <!--
                    OK  — applies pending changes and closes the dialog.
                -->
                <Button x:Name="OkButton"
                        Content="_OK"
                        Width="88"
                        Margin="0,0,6,0"
                        IsDefault="True"
                        Click="OkButton_Click"/>

                <!--
                    Cancel — rolls back any pending (OnConfirm) changes and closes.
                -->
                <Button x:Name="CancelButton"
                        Content="_Cancel"
                        Width="88"
                        Margin="0,0,6,0"
                        IsCancel="True"
                        Click="CancelButton_Click"/>

                <!--
                    Apply — flushes pending changes, keeps the dialog open.
                -->
                <Button x:Name="ApplyButton"
                        Content="_Apply"
                        Width="88"
                        Click="ApplyButton_Click"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>
